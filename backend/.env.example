# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Non-secret, structural config lives in config/*.yaml — only secrets belong here.
# Nested settings override YAML via SECTION__KEY (e.g. ELASTICSEARCH__API_KEY).

# --- Prometheus (metrics) ---
# For the SAP Prometheus behind the Portakal proxy, all three below are REQUIRED together
# (any one missing -> HTTP 401). PROMETHEUS_URL must include the proxy path prefix (…/portakal).
# For a plain single-tenant Prometheus, set only PROMETHEUS_URL and leave the rest blank.
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_TOKEN=            # Authorization: Bearer <token>
PROMETHEUS_ORG_ID=          # X-Scope-OrgID (multi-tenant Cortex/Mimir tenant, e.g. aksaray)
PROMETHEUS_PORTAKAL_TOKEN=  # X-Portakal-Token (the proxy gateway token)

# --- Elasticsearch (logs) ---
ELASTICSEARCH_HOSTS=https://elasticsearch:9200
ELASTICSEARCH_API_KEY=

# --- Langfuse (tracing, v4) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- LLM provider (OpenAI) ---
OPENAI_API_KEY=
